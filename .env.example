# =============================================================================
# Multando Frontend — Environment Variables
# =============================================================================
# Copy to `.env.local` and fill in.
#
#   cp .env.example .env.local
#
# NOTE: NEXT_PUBLIC_* vars are baked into the bundle at BUILD time and are
# visible in the browser. Never put secrets here — only public config.
# When building in Docker/Railway, pass them as build ARGs (not just runtime).
# =============================================================================

# Backend API URL — point to your self-hosted backend (include /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Environment
NEXT_PUBLIC_APP_ENV=production       # development | production

# Use built-in mock data instead of hitting the backend (local UI work)
NEXT_PUBLIC_USE_MOCK_DATA=false

# Google OAuth — WEB client ID (public; used for social login)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Solana (read-only display of on-chain MULTA balances/txns)
NEXT_PUBLIC_SOLANA_NETWORK=devnet    # devnet | testnet | mainnet-beta
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
